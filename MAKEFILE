# link everything into the chuck.tos executable
chuck.tos: $(OBJS) types.h
	$(CC) -g $(OBJS) -o chuck.tos


asynch.o: asynch.c asynch.h
	$(CC) -g -c asynch.c

chuck.o: chuck.c
	$(CC) -g -c chuck.c

cisr.o: cisr.c cisr.h
	$(CC) -g -c cisr.c

cond.o: cond.c cond.h
	$(CC) -g -c cond.c

effects.o: effects.c effects.h
	$(CC) -g -c effects.c

font.o: font.c font.h
	$(CC) -g -c font.c

game.o: game.c game.h
	$(CC) -g -c game.c

ikbd.o: ikbd.h ikbd.c
	$(CC) -g -c ikbd.c

input.o: input.c input.h
	$(CC) -g -c input.c

model.o: model.c model.h
	$(CC) -g -c model.c

psg.o: psg.c psg.h
	$(CC) -g -c psg.c

raster.o: raster.c raster.h
	$(CC) -g -c raster.c

renderer.o: renderer.h renderer.c
	$(CC) -g -c renderer.c

sound.o: sound.h sound.c
	$(CC) -g -c sound.c

start.o: start.h start.c
	$(CC) -g -c start.c

synch.o: synch.h synch.c
	$(CC) -g -c synch.c

# This handles your assembly VBL wrapper
cisr_asm.o: cisr_asm.s
	$(GLD) cisr_asm.s

rast_asm.o: rast_asm.s
	$(GLD) rast_asm.s

#-----------------TEST DRIVERS----------------
ikbd_tst.o: ikbd_tst.c
	$(CC) -g -c ikbd_tst.c

tst_st.o: tst_st.c
	$(CC) -g -c tst_st.c

tst_st.tos:	tst_st.o raster.o rast_asm.o model.o renderer.o cisr.o ikbd.o cisr_asm.o sound.o psg.o effects.o start.o font.o
	$(CC) tst_st.o raster.o rast_asm.o cisr.o ikbd.o cisr_asm.o sound.o psg.o effects.o start.o model.o renderer.o font.o -o tst_st.tos

ikbd.tos: ikbd_tst.o cisr.o cisr_asm.o ikbd.o raster.o rast_asm.o font.o
    $(CC) -g ikbd_tst.o cisr.o cisr_asm.o ikbd.o raster.o rast_asm.o font.o -o ikbd.tos