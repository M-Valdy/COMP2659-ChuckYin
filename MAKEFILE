CC = cc68x

# linking command
tst_rast.tos: tst_rast.o raster.o rast_asm.o font.o
	cc68x -g tst_rast.o raster.o rast_asm.o font.o -o tst_rast.tos

# indivisual compilation commands
tst_rast.o: tst_rast.c raster.h
	cc68x -g -c tst_rast.c

raster.o: raster.c raster.h
	cc68x -g -c raster.c

font.o: font.c font.h
	cc68x -g -c font.c

rast_asm.o: rast_asm.s
	gen -D -L2 rast_asm.s

model.o: model.c model.h
	cc68x -g -c model.c
cond.o: cond.c cond.h
	cc68x -g -c cond.c
asynch.o: asynch.c asynch.h
	cc68x -g -c asynch.c
synch.o: synch.c synch.h
	cc68x -g -c synch.c
renderer.o: renderer.c renderer.h
	cc68x -g -c renderer.c
events.o: events.c events.h
	cc68x -g -c events.c
input.o: input.c input.h
	cc68x -g -c input.c

# paolos awesome render test driver hehe
rendrtst.tos: rendrtst.o model.o cond.o asynch.o synch.o raster.o rast_asm.o font.o renderer.o events.o
	cc68x -g rendrtst.o model.o cond.o asynch.o synch.o raster.o rast_asm.o font.o renderer.o events.o -o rendrtst.tos
rendrtst.o: rendrtst.c
	$(CC) -g -c rendrtst.c

# paolos awesome model test driver hehe
modeltst.tos: modeltst.o model.o cond.o synch.o asynch.o
	cc68x -g modeltst.o model.o cond.o synch.o asynch.o -o modeltst.tos
modeltst.o: modeltst.c
	$(CC) -g -c modeltst.c

# main game module
frogger.tos: frogger.o model.o cond.o asynch.o synch.o raster.o rast_asm.o font.o renderer.o events.o input.o
	cc68x -g frogger.o model.o cond.o asynch.o synch.o raster.o rast_asm.o font.o renderer.o events.o input.o -o frogger.tos
frogger.o: frogger.c
	$(CC) -g -c frogger.c

# meagan's sound testing make files
tst_snd.tos: tst_snd.o psg.o
	cc68x -g tst_snd.o psg.o -o tst_snd.tos
tst_snd.o: tst_snd.c psg.o
	cc68x -g -c tst_snd.c
psg.o: psg.c psg.h
	cc68x -g -c psg.c